# pnpm configuration for hugin-desktop
# See: https://pnpm.io/npmrc

# Electron + native modules (better-sqlite3-multiple-ciphers, uiohook-napi,
# @koush/wrtc) need a flat, real node_modules. pnpm's default symlinked layout
# breaks electron-builder, electron-rebuild and node-gyp. "hoisted" gives an
# npm-like flat tree.
node-linker=hoisted

# Lock versions for extra safety: every `pnpm add` pins an exact version
# (no ^ / ~ ranges) so package.json matches the lockfile.
save-exact=true

# This dependency set predates pnpm's strict peer resolution; npm tolerated the
# mismatches. Keep installs working without silently auto-editing peers.
strict-peer-dependencies=false
